# Frontend build settings. Keep PUBLIC_SERVER empty when the frontend and
# Socket.IO are served through the same cloudflared hostname.
PUBLIC_SERVER=
PUBLIC_DEV_MODE=false
PUBLIC_MIN_PLAYERS=6

# Server settings.
PORT=3000
MIN_PLAYERS=6
DEV_MODE=false
ADMIN_SECRET=change-me-long-random-secret

# Usually empty in production because clients use the same origin.
# For a separate frontend dev server, comma-separate every allowed origin.
ALLOWED_ORIGINS=
